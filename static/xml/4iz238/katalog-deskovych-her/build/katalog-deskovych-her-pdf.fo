         <fo:block id="game-3"
                   border="1pt solid #ccc"
                   background-color="#F9FAFB"
                   padding="10pt"
                   margin-bottom="15pt"
                   keep-together.within-page="always">
            <fo:table width="100%" table-layout="fixed">
               <fo:table-column column-width="30%"/>
               <fo:table-column column-width="70%"/>
               <fo:table-body>
                  <fo:table-row>
                     <fo:table-cell padding-right="10pt">
                        <fo:block>
                           <fo:external-graphic src="img/codenames/krabice.png"
                                                content-width="scale-to-fit"
                                                width="4cm"/>
                        </fo:block>
                     </fo:table-cell>
                     <fo:table-cell>
                        <fo:block font-size="14pt" font-weight="bold" color="#111827">Krycí jména</fo:block>
                        <fo:block font-size="10pt" color="gray" margin-bottom="5pt">
                                (Codenames)
                            </fo:block>
                        <fo:block font-size="12pt"
                                  font-weight="bold"
                                  color="#4F46E5"
                                  margin-bottom="8pt">499 CZK<fo:inline color="black"
                                      font-weight="normal"
                                      font-size="10pt"
                                      margin-left="10pt">
                                    (Hodnocení: 9.0/10)
                                </fo:inline>
                        </fo:block>
                        <fo:block font-size="10pt" margin-bottom="8pt" text-align="justify">Týmová asociační párty hra. Dva hlavní špióni se snaží jednoslovnými
            nápovědami navést své týmy k odhalení všech správných karet (agentů) na stole.</fo:block>
                        <fo:block font-size="9pt">
                                Kategorie:
                                
                                Párty,Slovní,Dedukční</fo:block>
                     </fo:table-cell>
                  </fo:table-row>
               </fo:table-body>
