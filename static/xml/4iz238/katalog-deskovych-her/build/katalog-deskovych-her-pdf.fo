            <fo:table width="100%" table-layout="fixed">
               <fo:table-column column-width="30%"/>
               <fo:table-column column-width="70%"/>
               <fo:table-body>
                  <fo:table-row>
                     <fo:table-cell padding-right="10pt">
                        <fo:block>
                           <fo:external-graphic src="img/ticket/krabice.png"
                                                content-width="scale-to-fit"
                                                width="4cm"/>
                        </fo:block>
                     </fo:table-cell>
                     <fo:table-cell>
                        <fo:block font-size="14pt" font-weight="bold" color="#111827">Jízdenky, prosím! Evropa</fo:block>
                        <fo:block font-size="10pt" color="gray" margin-bottom="5pt">
                                (Ticket to Ride: Europe)
                            </fo:block>
                        <fo:block font-size="12pt"
                                  font-weight="bold"
                                  color="#4F46E5"
                                  margin-bottom="8pt">1 199 CZK<fo:inline color="black"
                                      font-weight="normal"
                                      font-size="10pt"
                                      margin-left="10pt">
                                    (Hodnocení: 8.5/10)
                                </fo:inline>
                        </fo:block>
                        <fo:block font-size="10pt" margin-bottom="8pt" text-align="justify">Hráči sbírají karty barevných vagónů, aby mohli obsazovat železniční tratě
            napříč Evropou. Body získávají za propojení měst určených tajnými kartami úkolů.</fo:block>
                        <fo:block font-size="9pt">
                                Kategorie:
                                
                                Rodinná,Strategická</fo:block>
                     </fo:table-cell>
                  </fo:table-row>
               </fo:table-body>
            </fo:table>
